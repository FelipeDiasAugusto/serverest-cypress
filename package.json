{
  "name": "serverest-cypress",
  "version": "2.0.0",
  "description": "Automação E2E dos fluxos de login e cadastro de usuários no ServeRest.",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test": "cypress run",
    "test:web": "cypress run --spec \"cypress/e2e/web/**/*.cy.js\"",
    "test:api": "cypress run --spec \"cypress/e2e/api/**/*.cy.js\"",
    "test:report": "cypress run --reporter cypress-mochawesome-reporter"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "cypress": "15.18.0",
    "cypress-mochawesome-reporter": "^4.0.2"
  },
  "overrides": {
    "serialize-javascript": "7.0.3",
    "uuid": "11.1.1"
  }
}
